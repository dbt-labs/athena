AWS_DEFAULT_REGION=us-east-1
ATHENA_OUTPUT_LOCATION=s3://your-bucket/athena-results/

# Optional: catalog and schema (defaults shown)
# ATHENA_CATALOG=AwsDataCatalog
# ATHENA_SCHEMA=default

# Optional: AWS profile name (switches auth to profile mode)
# AWS_PROFILE=my-profile

# Optional: explicit credentials (omit to use IAM role / ~/.aws/credentials)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
